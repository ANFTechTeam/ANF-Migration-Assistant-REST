    {
      "name": "Pre-Cutover and Cutover",
      "item": [
        {
          "name": "Get Replication Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apicloudurl}}/subscriptions/{{subscriptionId}}/resourceGroups/{{resourceGroupName}}/providers/Microsoft.NetApp/netAppAccounts/{{accountName}}/capacityPools/{{poolName}}/volumes/{{ma.volumeName}}/replicationStatus?api-version=2026-01-01",
              "host": [
                "{{apicloudurl}}"
              ],
              "path": [
                "subscriptions",
                "{{subscriptionId}}",
                "resourceGroups",
                "{{resourceGroupName}}",
                "providers",
                "Microsoft.NetApp",
                "netAppAccounts",
                "{{accountName}}",
                "capacityPools",
                "{{poolName}}",
                "volumes",
                "{{ma.volumeName}}",
                "replicationStatus"
              ],
              "query": [
                {
                  "key": "api-version",
                  "value": "2026-01-01"
                }
              ]
            },
            "description": "Returns the current replication status of the ANF target volume, including the replication health, mirror state, relationship status, and lag time. Use this request to monitor ongoing replication progress and confirm the volume is in sync before initiating cutover.\n\n**Key response fields:**\n- `healthy` — `true` if the replication relationship is healthy.\n- `mirrorState` — `Mirrored` indicates the volume is in sync; `Uninitialized` or `Broken-off` indicates an issue.\n- `relationshipStatus` — `Idle` means no transfer is in progress; `Transferring` means a sync is active.\n- `totalProgress` — Bytes transferred in the current or last transfer.\n- `lagTime` — Time since the last successful transfer completed.\n\n**Required variables:** `apicloudurl`, `subscriptionId`, `resourceGroupName`, `accountName`, `poolName`, `ma.volumeName`"
          },
          "response": []
        },
        {
          "name": "Change Replication Schedule",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
