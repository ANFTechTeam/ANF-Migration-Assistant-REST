        {
          "name": "Step 1. Create Target Volume",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "let asyncOperationValue = pm.response.headers.get('azure-asyncoperation');",
                  "",
                  "if (asyncOperationValue) {",
                  "    pm.environment.set('ma.Azure-AsyncOperationID', asyncOperationValue);",
                  "} else {",
                  "    console.warn(\"azure-asyncoperation header not found\");",
                  "}",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
